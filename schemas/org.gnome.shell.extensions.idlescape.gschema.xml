<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.idlescape" path="/org/gnome/shell/extensions/idlescape/">
    <key name="video-path" type="s">
      <default>""</default>
      <summary>Video file path</summary>
      <description>Absolute path to the video file to be used as a screensaver.</description>
    </key>
    <key name="idle-timeout" type="i">
      <default>90</default>
      <summary>Idle timeout</summary>
      <description>Seconds of inactivity before the screensaver triggers.</description>
    </key>
    <key name="enabled" type="b">
      <default>true</default>
      <summary>Enable screensaver</summary>
      <description>Whether the video screensaver is active.</description>
    </key>
    <key name="backend-mode" type="s">
      <default>"bash"</default>
      <summary>Backend Mode</summary>
      <description>Select the backend: 'bash' or 'native'.</description>
    </key>
  </schema>
</schemalist>
